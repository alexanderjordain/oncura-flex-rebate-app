# Copy to secrets.toml locally (gitignored), or paste into Streamlit Cloud > App > Settings > Secrets.
# Single-line TOML is valid: KEY = "value"

# GitHub Contents API token (Contents:write on the repo) for persisting master/config edits.
GITHUB_TOKEN = "ghp_xxx"

# Shared app password. Anyone with the public URL must enter this to get in.
APP_PASSWORD = "change-me"

# Role passwords (optional). If set, entering one of these selects that role and unlocks
# approval gates. If unset, everyone authenticated with APP_PASSWORD is treated as "viewer".
[roles]
alex     = "alex-pw"       # full admin
tanya    = "tanya-pw"      # operator: run cycles, generate imports, approve
jennifer = "jennifer-pw"   # controller: review + approve
marty    = "marty-pw"      # CFO: review + approve

# Later: QBO OAuth + OPD API creds go here when available.
# [qbo]
# client_id = ""
# client_secret = ""
# refresh_token = ""
# realm_id = ""
