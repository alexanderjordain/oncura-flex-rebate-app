# Copy to secrets.toml locally (gitignored), or paste into Streamlit Cloud > App > Settings > Secrets.
# Single-line TOML is valid: KEY = "value"

# Shared app password. Anyone with the public URL must enter this. With no [roles] table
# (our setup), entering this grants full access.
APP_PASSWORD = "change-me"

# GitHub Contents API token (Contents:write on the repo) for persisting master/config edits.
# Optional: without it the app runs fine, but master edits won't persist.
GITHUB_TOKEN = "ghp_xxx"

# OPTIONAL — leave this commented out unless you want per-person permission splits.
# Adding it makes APP_PASSWORD read-only and requires a role password to take actions.
# [roles]
# alex     = "alex-pw"       # full admin
# tanya    = "tanya-pw"      # operator: run cycles, generate imports, approve
# jennifer = "jennifer-pw"   # controller: review + approve
# marty    = "marty-pw"      # CFO: review + approve

# OPD Mendix OData credentials. Used by Stage 3 of the FLEX Cycle to pull
# quarter-end invoice data live from telehealth.oncurapartners.com (no manual
# export needed). Without these, Stage 3 falls back to the file-upload path.
# Use a dedicated service account (e.g. flex-app-svc), NOT a personal login —
# audit logs should distinguish "the app pulled this" from "a human pulled this."
OPD_ODATA_USER = "service-account-username"
OPD_ODATA_PASS = "service-account-password"

# Later: QBO OAuth goes here when available.
# [qbo]
# client_id = ""
# client_secret = ""
# refresh_token = ""
# realm_id = ""
